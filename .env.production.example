APP_NAME="Reservasi Kunjungan UPI"
APP_ENV=production
APP_KEY=           # php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://nama-app-anda.onrender.com

APP_LOCALE=id
APP_FALLBACK_LOCALE=id

# ============================================================
# DATABASE — Supabase PostgreSQL
# Daftar: https://supabase.com → New Project → Settings > Database
# Ambil: Host, Port, DB Name, User, Password
# ============================================================
DB_CONNECTION=pgsql
DB_HOST=db.xxxxxxxx.supabase.co
DB_PORT=5432
DB_DATABASE=postgres
DB_USERNAME=postgres
DB_PASSWORD=password-supabase-anda

# ============================================================
# CLOUDINARY — File Storage
# Daftar: https://cloudinary.com/users/register_free
# Ambil dari: Dashboard > API Keys
# ============================================================
FILESYSTEM_DISK=cloudinary
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxx
CLOUDINARY_CLOUD_NAME=nama-cloud-anda

# Session & Cache (cookie/array aman untuk Render)
SESSION_DRIVER=cookie
SESSION_LIFETIME=120
CACHE_STORE=array
QUEUE_CONNECTION=sync

# Mail (log dulu, ganti ke SMTP jika sudah ada)
MAIL_MAILER=log
MAIL_FROM_ADDRESS=humas@upi.edu
MAIL_FROM_NAME="Humas UPI - Reservasi Kunjungan"

# Akun admin awal
ADMIN_EMAIL=admin@upi.edu
ADMIN_PASSWORD=GantiPasswordIni123!
